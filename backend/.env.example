PORT=8787
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-read
TRACECHECK_SERVICE_NAME=tracecheck-backend
TRACECHECK_AUTH_MODE=session
TRACECHECK_API_TOKENS=ops-admin:replace-me:ops-admin,qa-operator:replace-me:qa-operator
TRACECHECK_DATABASE_DRIVER=postgres
TRACECHECK_DATABASE_URL=postgresql://tracecheck:tracecheck@127.0.0.1:5432/tracecheck
TRACECHECK_DATABASE_SSL=false
TRACECHECK_DATABASE_AUTO_MIGRATE=true
TRACECHECK_FREEZE_WRITE_OPERATIONS=false
TRACECHECK_STRICT_STARTUP_CHECKS=false
TRACECHECK_ALERT_WEBHOOK_URL=
TRACECHECK_AUDIT_LOG_PATH=var/audit/tracecheck-audit.ndjson
TRACECHECK_AUDIT_EVENT_BUFFER_SIZE=200
TRACECHECK_MAX_FILE_SIZE_MB=10
TRACECHECK_ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,text/plain,text/csv
TRACECHECK_ALLOWED_UPLOAD_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.webp,.txt,.csv
TRACECHECK_RATE_LIMIT_WINDOW_MS=60000
TRACECHECK_RATE_LIMIT_AUTH_MAX_REQUESTS=20
TRACECHECK_RATE_LIMIT_STATUS_MAX_REQUESTS=120
TRACECHECK_RATE_LIMIT_ANALYSIS_MAX_REQUESTS=60
TRACECHECK_RATE_LIMIT_UPLOAD_MAX_REQUESTS=20
TRACECHECK_RATE_LIMIT_OPS_MAX_REQUESTS=30
TRACECHECK_RATE_LIMIT_HEALTH_MAX_REQUESTS=120
